# PORT: The port your backend server will run on
PORT=5000

# MONGODB_URI: The connection string for your MongoDB database. 
# Keep it as 'mongodb://127.0.0.1:27017/vivek_rakhsha' for local development.
MONGODB_URI=mongodb://127.0.0.1:27017/vivek_rakhsha

# JWT_SECRET: A secret key used to sign login tokens. 
# You can change this to any random string.
JWT_SECRET=your_secret_key_here_123456
